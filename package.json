{
  "name": "noah-frontend",
  "version": "1.0.1",
  "private": true,
   "engines": {
    "node": "16.20.2",
    "npm": ">=8 <9"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "build:prod": "cross-env NODE_ENV=production ng build --prod && cp $(pwd)/.netlify/_redirects $(pwd)/dist/noah-frontend/_redirects",
    "build-noah-ph": "cross-env NODE_ENV=production ng build -c=noahPH && cp $(pwd)/.netlify/_redirects $(pwd)/dist/noah-frontend/_redirects",
    "version": "conventional-changelog -p angular -i CHANGELOG.md -s && git add CHANGELOG.md"
  },
  "dependencies": {
    "@angular/animations": "13.4.0",
    "@angular/cdk": "13.3.9",
    "@angular/common": "13.4.0",
    "@angular/compiler": "13.4.0",
    "@angular/core": "13.4.0",
    "@angular/forms": "13.4.0",
    "@angular/material": "13.3.9",
    "@angular/platform-browser": "13.4.0",
    "@angular/platform-browser-dynamic": "13.4.0",
    "@angular/router": "13.4.0",
    "@angular/service-worker": "13.4.0",

    "mapbox-gl": "2.15.0",
    "@mapbox/mapbox-gl-draw": "1.5.0",
    "@mapbox/mapbox-gl-geocoder": "4.7.4",

    "@turf/turf": "6.5.0",
    "highcharts": "9.3.3",
    "highcharts-angular": "2.10.0",
    "ngx-google-analytics": "11.2.1",
    "rxjs": "7.4.0",
    "swiper": "6.8.4",
    "tslib": "2.3.1",
    "zone.js": "0.11.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "13.3.11",
    "@angular/cli": "13.3.11",
    "@angular/compiler-cli": "13.4.0",

    "@types/mapbox-gl": "2.4.2",
    "@types/node": "16.11.7",
    "@types/jasmine": "3.6.0",

    "typescript": "4.6.4",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.1.1",
    "karma-coverage": "~2.0.3",
    "karma-jasmine": "~4.0.2",
    "karma-jasmine-html-reporter": "1.7.0",
    "jasmine-core": "~3.6.0",
    "cross-env": "7.0.3",

    "@types/geojson": "7946.0.8",
    "codelyzer": "^6.0.0",
    "conventional-changelog-cli": "^2.1.1",
    "husky": "^4.3.8",
    "jasmine-spec-reporter": "~5.0.0",
    "prettier": "2.4.1",
    "pretty-quick": "^3.1.1",
    "protractor": "~7.0.0",
    "tailwindcss": "^2.2.19",
    "ts-node": "8.3.0",
    "tslint": "~6.1.0",
    "tslint-config-prettier": "^1.18.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "pretty-quick --staged"
    }
  }
}
